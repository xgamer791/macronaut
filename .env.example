# Copy this file to .env and fill in your own values.
# Never commit .env — it is gitignored.

# USDA FoodData Central API key (free): https://fdc.nal.usda.gov/api-key-signup
# If unset, the app falls back to DEMO_KEY, which is heavily rate-limited
# (roughly 30 requests/hour) but fine for a quick try.
EXPO_PUBLIC_USDA_API_KEY=

# Open Food Facts requires no API key.

# Set by the GitHub Pages deploy workflow only — leave empty for local dev.
EXPO_PUBLIC_BASE_PATH=
