# Copy this file to .env and fill in your own values.
# Never commit .env — it is gitignored.

# USDA FoodData Central API key (free): https://fdc.nal.usda.gov/api-key-signup
# If unset, the app falls back to DEMO_KEY, which is heavily rate-limited
# (roughly 30 requests/hour) but fine for a quick try.
EXPO_PUBLIC_USDA_API_KEY=

# Nutritionix Track API (optional): https://www.nutritionix.com/business/api
# When unset, the Nutritionix provider is inactive (returns no results).
EXPO_PUBLIC_NUTRITIONIX_APP_ID=
EXPO_PUBLIC_NUTRITIONIX_APP_KEY=

# FatSecret Platform API (optional): https://platform.fatsecret.com
# OAuth2 client credentials. When unset, the FatSecret provider is inactive.
EXPO_PUBLIC_FATSECRET_CLIENT_ID=
EXPO_PUBLIC_FATSECRET_CLIENT_SECRET=

# Open Food Facts requires no API key.
# Bundled restaurant nutrition (McDonald's, Chipotle, Starbucks, …) needs no key.

# Set by the GitHub Pages deploy workflow only — leave empty for local dev.
EXPO_PUBLIC_BASE_PATH=
